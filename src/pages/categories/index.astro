---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { categories } from '../../data/constants';
import businessData from '../../data/businesses.json';

const businesses = businessData as any[];
const categoriesWithCounts = categories.map(cat => ({
  ...cat,
  count: businesses.filter(b => b.categories?.includes(cat.name)).length,
}));
---

<Layout title="Browse Categories — Jackson County MS">
  <Header activePage="Categories" />

  <section class="page-hero">
    <div class="container">
      <span class="page-eyebrow">Business Directory</span>
      <h1>Browse Categories</h1>
      <p>Find businesses by category across Jackson County, Mississippi.</p>
    </div>
  </section>

  <section class="categories-section">
    <div class="container">
      <div class="cat-grid">
        {categoriesWithCounts.map(cat => (
          <a href={`/categories/${cat.slug}/`} class="cat-card animate">
            <span class="cat-icon">{cat.icon}</span>
            <div class="cat-info">
              <h3>{cat.name}</h3>
              <span class="cat-count">{cat.count} businesses</span>
            </div>
            <span class="cat-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    padding: 8rem 0 3.5rem;
    text-align: center;
  }

  .page-eyebrow {
    display: inline-block;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }

  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--white);
    margin-bottom: 0.75rem;
  }

  .page-hero p {
    color: rgba(255,255,255,0.7);
    font-size: 1.1rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .categories-section {
    padding: 3.5rem 0 5rem;
    background: var(--gray-100);
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .cat-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    transition: all 0.25s;
  }

  .cat-card:hover {
    border-color: var(--teal);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .cat-icon { font-size: 2rem; flex-shrink: 0; }

  .cat-info { flex: 1; }

  .cat-info h3 {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--navy);
    margin-bottom: 0.15rem;
  }

  .cat-count {
    font-size: 0.82rem;
    color: var(--gray-600);
  }

  .cat-arrow {
    color: var(--teal);
    font-size: 1.2rem;
    transition: transform 0.25s;
    flex-shrink: 0;
  }

  .cat-card:hover .cat-arrow { transform: translateX(4px); }

  @media (max-width: 900px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .cat-grid { grid-template-columns: 1fr; }
  }
</style>
