---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { towns, categories } from '../data/constants';
import businessData from '../data/businesses.json';

const businesses = businessData as any[];
const deals = businesses.filter(b => b.deal_title && b.deal_title.trim());
---

<Layout title="Jackson County MS — Discover Local Businesses & Community">

  <Header activePage="Home" />

  <!-- ════════════════════ HERO ════════════════════ -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/hero-beach.jpg" alt="White sand beach on the Mississippi Gulf Coast" width="1536" height="1152" loading="eager" />
    </div>
    <div class="hero-overlay"></div>

    <div class="hero-content container">
      <span class="hero-eyebrow animate">Jackson County, Mississippi</span>
      <h1 class="animate delay-1">Find Local Coupons &amp;<br/>Businesses in Jackson County</h1>
      <p class="hero-subtitle animate delay-2">
        Discover deals, events, and services across six vibrant communities
        on the Mississippi Gulf Coast.
      </p>

      <div class="hero-cities animate delay-3">
        {towns.map(town => (
          <a href={`/locations/${town.slug}/`} class="hero-city-card">
            <strong>{town.name}</strong>
            <span>{town.businesses} businesses</span>
          </a>
        ))}
      </div>

      <div class="hero-search animate delay-4">
        <div class="search-box">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" placeholder="Search businesses, restaurants, services..." aria-label="Search businesses" />
          <button class="btn btn-gold">Search</button>
        </div>
      </div>

      <div class="hero-stats animate delay-4">
        <div class="stat"><strong>6</strong> Cities</div>
        <div class="stat-divider"></div>
        <div class="stat"><strong>18</strong> Categories</div>
        <div class="stat-divider"></div>
        <div class="stat"><strong>435</strong> Businesses</div>
      </div>
    </div>

    <div class="hero-wave">
      <svg viewBox="0 0 1440 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,100 1080,0 1440,60 L1440,100 L0,100 Z" fill="var(--white)"/>
      </svg>
    </div>
  </section>

  <!-- ════════════════════ TOWNS ════════════════════ -->
  <section class="towns" id="towns">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Our Communities</span>
        <h2>Explore Jackson County Cities</h2>
        <p>Six unique communities, each with their own character and charm.</p>
      </div>

      <div class="towns-grid">
        {towns.map((town, i) => (
          <a href={`/locations/${town.slug}/`} class={`town-card animate delay-${(i % 4) + 1}`}>
            <h3>{town.name}</h3>
            <p>{town.businesses} businesses</p>
            <span class="town-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════ FEATURED IMAGE ════════════════════ -->
  <section class="showcase">
    <div class="container">
      <div class="showcase-card animate">
        <img src="/images/ocean-springs.jpg" alt="Ocean Springs bridge at sunset over the Mississippi Sound" width="1536" height="1024" loading="lazy" />
        <div class="showcase-overlay">
          <span class="showcase-badge">Featured Community</span>
          <h3>Ocean Springs</h3>
          <p>Art galleries, live music, and Gulf Coast seafood in one of Mississippi's most beloved small towns.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════ CATEGORIES ════════════════════ -->
  <section class="categories" id="categories">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Browse the Directory</span>
        <h2>Find What You Need</h2>
        <p>From dining to home services — discover trusted local businesses.</p>
      </div>

      <div class="cat-grid">
        {categories.map((cat, i) => (
          <a href={`/categories/${cat.slug}/`} class={`cat-card animate delay-${(i % 4) + 1}`}>
            <span class="cat-icon">{cat.icon}</span>
            <span class="cat-name">{cat.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════ DEALS / COUPONS ════════════════════ -->
  <section class="deals" id="deals">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Save Local</span>
        <h2>Featured Coupons & Deals</h2>
        <p>Exclusive offers from Jackson County businesses.</p>
      </div>

      {deals.length > 0 ? (
        <div class="deals-grid">
          {deals.map(biz => (
            <a href={`/listing/${biz.slug}/`} class="deal-card animate">
              <div class="deal-badge">Deal</div>
              <h3>{biz.deal_title}</h3>
              <p class="deal-biz">{biz.title}</p>
              {biz.deal_description && <p class="deal-desc">{biz.deal_description}</p>}
              <div class="deal-footer">
                {biz.deal_expiry && <span class="deal-expiry">Expires: {biz.deal_expiry}</span>}
                <span class="deal-redeem">Redeem &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="deals-empty animate">
          <span class="deals-empty-icon">🎟️</span>
          <p>New deals coming soon! Business owners can <a href="/pricing/">post deals</a> with a Featured listing.</p>
        </div>
      )}

      <div class="deals-cta">
        <a href="/deals/" class="btn btn-gold">View All Deals</a>
        <a href="/pricing/" class="btn btn-ghost-dark">Post Your Deal</a>
      </div>
    </div>
  </section>

  <!-- ════════════════════ ABOUT / CTA ════════════════════ -->
  <section class="about-cta" id="about">
    <div class="container">
      <div class="cta-card">
        <div class="cta-content">
          <span class="section-eyebrow" style="color:var(--gold-light);">About JacksonCountyMS.com</span>
          <h2>Your Gateway to the Gulf Coast</h2>
          <p>
            We connect residents and visitors with the best local businesses,
            services, and events in Jackson County, Mississippi. Whether you're
            looking for a great restaurant in Ocean Springs, a contractor in
            Vancleave, or community events in Pascagoula — we've got you covered.
          </p>
          <div class="cta-buttons">
            <a href="/contact/" class="btn btn-white">Add Your Business</a>
            <a href="/listings/" class="btn btn-ghost">Browse Directory</a>
          </div>
        </div>
        <div class="cta-features">
          <div class="feature">
            <div class="feature-icon">📍</div>
            <div>
              <strong>Local Focus</strong>
              <p>Exclusively serving Jackson County communities</p>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon">⭐</div>
            <div>
              <strong>Verified Listings</strong>
              <p>Every business reviewed for accuracy</p>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon">🎟️</div>
            <div>
              <strong>Deals & Coupons</strong>
              <p>Exclusive offers from local businesses</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />

</Layout>

<style>
  /* ════════════════════ BUTTONS ════════════════════ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.6rem;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    transition: all 0.25s;
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  .btn-sm { padding: 0.5rem 1.2rem; font-size: 0.85rem; }
  .btn-lg { padding: 0.9rem 2.2rem; font-size: 1rem; }

  .btn-gold {
    background: var(--gold);
    color: var(--navy);
    border-color: var(--gold);
  }

  .btn-gold:hover {
    background: var(--gold-light);
    border-color: var(--gold-light);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(232,160,32,0.35);
  }

  .btn-white {
    background: var(--white);
    color: var(--navy);
    border-color: var(--white);
  }

  .btn-white:hover {
    background: var(--cream);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-ghost {
    background: transparent;
    color: var(--white);
    border-color: rgba(255,255,255,0.35);
  }

  .btn-ghost:hover {
    border-color: var(--white);
    background: rgba(255,255,255,0.08);
    transform: translateY(-1px);
  }

  /* ════════════════════ HERO ════════════════════ */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(13,33,55,0.85) 0%, rgba(13,33,55,0.5) 40%, rgba(13,33,55,0.7) 100%),
      linear-gradient(135deg, rgba(26,127,122,0.15) 0%, transparent 60%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 8rem 0 6rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    display: inline-block;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.25rem;
    padding: 0.4rem 1rem;
    background: rgba(232,160,32,0.12);
    border-radius: 100px;
    border: 1px solid rgba(232,160,32,0.2);
  }

  .hero h1 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.8);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
    font-weight: 300;
  }

  .hero-search { max-width: 600px; margin: 0 auto 2.5rem; }

  .search-box {
    display: flex;
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    position: relative;
  }

  .search-icon {
    position: absolute;
    left: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--gray-400);
    pointer-events: none;
  }

  .search-box input {
    flex: 1;
    border: none;
    padding: 1rem 1rem 1rem 3rem;
    font-size: 1rem;
    font-family: var(--font-body);
    color: var(--gray-800);
    outline: none;
    background: transparent;
    min-width: 0;
  }

  .search-box input::placeholder { color: var(--gray-400); }

  .search-box .btn {
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    padding: 1rem 1.8rem;
    font-size: 0.95rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .stat {
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
  }

  .stat strong {
    color: var(--gold);
    font-size: 1.4rem;
    font-family: var(--font-heading);
    margin-right: 0.35rem;
  }

  .stat-divider {
    width: 1px;
    height: 24px;
    background: rgba(255,255,255,0.2);
  }

  .hero-cities {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    max-width: 700px;
    margin: 2.5rem auto 2rem;
  }

  .hero-city-card {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.25rem;
    background: rgba(13,33,55,0.55);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-sm);
    transition: background 0.25s, border-color 0.25s;
  }

  .hero-city-card:hover {
    background: rgba(13,33,55,0.75);
    border-color: rgba(255,255,255,0.25);
  }

  .hero-city-card strong {
    color: var(--white);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .hero-city-card span {
    color: var(--gold);
    font-size: 0.78rem;
    font-weight: 600;
  }

  .hero-wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    z-index: 3;
    line-height: 0;
  }

  .hero-wave svg {
    width: 100%;
    height: 80px;
  }

  /* ════════════════════ SECTION HEADERS ════════════════════ */
  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3.5rem;
  }

  .section-eyebrow {
    display: inline-block;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    color: var(--navy);
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .section-header p {
    color: var(--gray-600);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* ════════════════════ TOWNS ════════════════════ */
  .towns {
    padding: 5rem 0;
    background: var(--white);
  }

  .towns-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .town-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 2rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .town-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--teal), var(--teal-light));
    transform: scaleX(0);
    transition: transform 0.3s;
    transform-origin: left;
  }

  .town-card:hover {
    border-color: var(--teal);
    box-shadow: var(--shadow-glow);
    transform: translateY(-4px);
  }

  .town-card:hover::before { transform: scaleX(1); }

  .town-card h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 0.4rem;
  }

  .town-card p {
    color: var(--gray-600);
    font-size: 0.9rem;
    line-height: 1.5;
    flex: 1;
  }

  .town-arrow {
    color: var(--teal);
    font-size: 1.2rem;
    margin-top: 1rem;
    transition: transform 0.25s;
  }

  .town-card:hover .town-arrow { transform: translateX(6px); }

  /* ════════════════════ SHOWCASE ════════════════════ */
  .showcase {
    padding: 0 0 5rem;
  }

  .showcase-card {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 2.4 / 1;
    box-shadow: var(--shadow-lg);
  }

  .showcase-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 6s ease;
  }

  .showcase-card:hover img { transform: scale(1.05); }

  .showcase-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(13,33,55,0.85) 0%, transparent 60%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 3rem;
  }

  .showcase-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .showcase-overlay h3 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .showcase-overlay p {
    color: rgba(255,255,255,0.8);
    font-size: 1rem;
    max-width: 500px;
    line-height: 1.6;
  }

  /* ════════════════════ CATEGORIES ════════════════════ */
  .categories {
    padding: 5rem 0;
    background: var(--gray-100);
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .cat-card {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1.15rem 1.25rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    transition: all 0.25s;
  }

  .cat-card:hover {
    border-color: var(--teal);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .cat-icon { font-size: 1.5rem; flex-shrink: 0; }

  .cat-name {
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--navy);
  }

  /* ════════════════════ DEALS ════════════════════ */
  .deals {
    padding: 5rem 0;
    background: var(--white);
  }

  .deals-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .deal-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    position: relative;
    transition: all 0.25s;
  }

  .deal-card:hover {
    border-color: var(--gold);
    box-shadow: 0 4px 20px rgba(232,160,32,0.12);
    transform: translateY(-2px);
  }

  .deal-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--white);
    background: var(--gold);
    padding: 0.2rem 0.7rem;
    border-radius: 100px;
  }

  .deal-card h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--navy);
    margin-bottom: 0.35rem;
    padding-right: 3rem;
  }

  .deal-biz {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--teal);
    margin-bottom: 0.5rem;
  }

  .deal-desc {
    font-size: 0.88rem;
    color: var(--gray-600);
    line-height: 1.5;
    flex: 1;
    margin-bottom: 0.75rem;
  }

  .deal-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .deal-expiry {
    font-size: 0.78rem;
    color: var(--gray-400);
  }

  .deal-redeem {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--gold);
  }

  .deals-empty {
    text-align: center;
    padding: 3rem 1rem;
    margin-bottom: 2rem;
  }

  .deals-empty-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .deals-empty p {
    color: var(--gray-600);
    font-size: 1rem;
  }

  .deals-empty a {
    color: var(--teal);
    font-weight: 600;
  }

  .deals-empty a:hover { text-decoration: underline; }

  .deals-cta {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-ghost-dark {
    background: transparent;
    color: var(--navy);
    border-color: var(--gray-200);
  }

  .btn-ghost-dark:hover {
    border-color: var(--teal);
    color: var(--teal);
    transform: translateY(-1px);
  }

  /* ════════════════════ ABOUT / CTA ════════════════════ */
  .about-cta {
    padding: 5rem 0;
  }

  .cta-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    border-radius: var(--radius-xl);
    padding: 4rem;
    overflow: hidden;
    position: relative;
  }

  .cta-card::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(circle, rgba(26,127,122,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-content { position: relative; z-index: 1; }

  .cta-content h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--white);
    margin-bottom: 1rem;
    line-height: 1.25;
  }

  .cta-content p {
    color: rgba(255,255,255,0.75);
    line-height: 1.8;
    margin-bottom: 2rem;
    font-size: 1rem;
  }

  .cta-buttons { display: flex; gap: 1rem; flex-wrap: wrap; }

  .cta-features {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    position: relative;
    z-index: 1;
  }

  .feature {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .feature-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.05);
