---
import Layout from '../layouts/Layout.astro';

const towns = [
  { name: 'Ocean Springs', icon: '🎨', desc: 'Arts, culture & coastal charm' },
  { name: 'Pascagoula', icon: '⚓', desc: 'Maritime heritage & industry' },
  { name: 'Gautier', icon: '🌿', desc: 'Nature trails & bayou life' },
  { name: 'Moss Point', icon: '🌊', desc: 'Waterways & community spirit' },
  { name: 'Vancleave', icon: '🌲', desc: 'Rural beauty & open spaces' },
  { name: 'Escatawpa', icon: '🏡', desc: 'Small-town Southern living' },
];

const categories = [
  { name: 'Restaurants & Dining', icon: '🍽️' },
  { name: 'Shopping & Retail', icon: '🛍️' },
  { name: 'Health & Medical', icon: '🏥' },
  { name: 'Home Services', icon: '🔧' },
  { name: 'Auto Services', icon: '🚗' },
  { name: 'Beauty & Personal Care', icon: '💇' },
  { name: 'Arts & Entertainment', icon: '🎭' },
  { name: 'Outdoors & Recreation', icon: '🏖️' },
  { name: 'Professional Services', icon: '💼' },
  { name: 'Real Estate', icon: '🏠' },
  { name: 'Education & Childcare', icon: '📚' },
  { name: 'Financial Services', icon: '🏦' },
  { name: 'Bars & Nightlife', icon: '🍸' },
  { name: 'Churches & Religious', icon: '⛪' },
  { name: 'Community & Nonprofits', icon: '🤝' },
  { name: 'Animal & Pet Services', icon: '🐾' },
];
---

<Layout title="Jackson County MS — Discover Local Businesses & Community">

  <!-- ════════════════════ HEADER ════════════════════ -->
  <header class="site-header" id="header">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label="Jackson County MS Home">
        <div class="logo-mark">
          <span class="logo-jc">JC</span>
          <span class="logo-ms">MS</span>
        </div>
        <div class="logo-text">
          <span class="logo-title">Jackson County</span>
          <span class="logo-sub">Mississippi</span>
        </div>
      </a>

      <nav class="nav-desktop" aria-label="Primary">
        <a href="#towns">Towns</a>
        <a href="#categories">Directory</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </nav>

      <a href="#contact" class="btn btn-gold btn-sm header-cta">Get Listed</a>

      <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>

    <nav class="nav-mobile" id="mobile-menu" aria-label="Mobile navigation">
      <a href="#towns">Towns</a>
      <a href="#categories">Directory</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
      <a href="#contact" class="btn btn-gold" style="margin-top:0.5rem;text-align:center;">Get Listed</a>
    </nav>
  </header>

  <!-- ════════════════════ HERO ════════════════════ -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/hero-beach.jpg" alt="White sand beach on the Mississippi Gulf Coast" width="1536" height="1152" loading="eager" />
    </div>
    <div class="hero-overlay"></div>

    <div class="hero-content container">
      <span class="hero-eyebrow animate">Gulf Coast Living</span>
      <h1 class="animate delay-1">Discover Jackson County,<br/>Mississippi</h1>
      <p class="hero-subtitle animate delay-2">
        Find local businesses, events, and deals across six vibrant communities
        on the Mississippi Gulf Coast.
      </p>

      <div class="hero-search animate delay-3">
        <div class="search-box">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" placeholder="Search businesses, restaurants, services..." aria-label="Search businesses" />
          <button class="btn btn-gold">Search</button>
        </div>
      </div>

      <div class="hero-stats animate delay-4">
        <div class="stat"><strong>6</strong> Towns</div>
        <div class="stat-divider"></div>
        <div class="stat"><strong>16</strong> Categories</div>
        <div class="stat-divider"></div>
        <div class="stat"><strong>100+</strong> Businesses</div>
      </div>
    </div>

    <div class="hero-wave">
      <svg viewBox="0 0 1440 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,100 1080,0 1440,60 L1440,100 L0,100 Z" fill="var(--white)"/>
      </svg>
    </div>
  </section>

  <!-- ════════════════════ TOWNS ════════════════════ -->
  <section class="towns" id="towns">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Our Communities</span>
        <h2>Explore Jackson County Towns</h2>
        <p>Six unique communities, each with their own character and charm.</p>
      </div>

      <div class="towns-grid">
        {towns.map((town, i) => (
          <a href={`#${town.name.toLowerCase().replace(/\s/g, '-')}`} class={`town-card animate delay-${(i % 4) + 1}`}>
            <span class="town-icon">{town.icon}</span>
            <h3>{town.name}</h3>
            <p>{town.desc}</p>
            <span class="town-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════ FEATURED IMAGE ════════════════════ -->
  <section class="showcase">
    <div class="container">
      <div class="showcase-card animate">
        <img src="/images/ocean-springs.jpg" alt="Ocean Springs bridge at sunset over the Mississippi Sound" width="1536" height="1024" loading="lazy" />
        <div class="showcase-overlay">
          <span class="showcase-badge">Featured Community</span>
          <h3>Ocean Springs</h3>
          <p>Art galleries, live music, and Gulf Coast seafood in one of Mississippi's most beloved small towns.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════ CATEGORIES ════════════════════ -->
  <section class="categories" id="categories">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Browse the Directory</span>
        <h2>Find What You Need</h2>
        <p>From dining to home services — discover trusted local businesses.</p>
      </div>

      <div class="cat-grid">
        {categories.map((cat, i) => (
          <a href="#" class={`cat-card animate delay-${(i % 4) + 1}`}>
            <span class="cat-icon">{cat.icon}</span>
            <span class="cat-name">{cat.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════ ABOUT / CTA ════════════════════ -->
  <section class="about-cta" id="about">
    <div class="container">
      <div class="cta-card">
        <div class="cta-content">
          <span class="section-eyebrow" style="color:var(--gold-light);">About JacksonCountyMS.com</span>
          <h2>Your Gateway to the Gulf Coast</h2>
          <p>
            We connect residents and visitors with the best local businesses,
            services, and events in Jackson County, Mississippi. Whether you're
            looking for a great restaurant in Ocean Springs, a contractor in
            Vancleave, or community events in Pascagoula — we've got you covered.
          </p>
          <div class="cta-buttons">
            <a href="#contact" class="btn btn-white">Add Your Business</a>
            <a href="#categories" class="btn btn-ghost">Browse Directory</a>
          </div>
        </div>
        <div class="cta-features">
          <div class="feature">
            <div class="feature-icon">📍</div>
            <div>
              <strong>Local Focus</strong>
              <p>Exclusively serving Jackson County communities</p>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon">⭐</div>
            <div>
              <strong>Verified Listings</strong>
              <p>Every business reviewed for accuracy</p>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon">🎟️</div>
            <div>
              <strong>Deals & Coupons</strong>
              <p>Exclusive offers from local businesses</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════ CONTACT ════════════════════ -->
  <section class="contact" id="contact">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Get in Touch</span>
        <h2>List Your Business</h2>
        <p>Ready to reach more local customers? Add your business to the Jackson County directory.</p>
      </div>

      <form class="contact-form animate" action="#" method="post">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" placeholder="John Smith" required />
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="john@example.com" required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="business">Business Name</label>
            <input type="text" id="business" name="business" placeholder="Your Business LLC" />
          </div>
          <div class="form-group">
            <label for="town">Town</label>
            <select id="town" name="town">
              <option value="">Select a town...</option>
              {towns.map(t => <option value={t.name}>{t.name}</option>)}
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="4" placeholder="Tell us about your business..."></textarea>
        </div>
        <button type="submit" class="btn btn-gold btn-lg">Submit Listing Request</button>
      </form>
    </div>
  </section>

  <!-- ════════════════════ FOOTER ════════════════════ -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="logo" style="margin-bottom:1rem;">
            <div class="logo-mark">
              <span class="logo-jc">JC</span>
              <span class="logo-ms">MS</span>
            </div>
            <div class="logo-text">
              <span class="logo-title">Jackson County</span>
              <span class="logo-sub">Mississippi</span>
            </div>
          </div>
          <p>Connecting communities and businesses across Jackson County on the Mississippi Gulf Coast.</p>
        </div>

        <div class="footer-links">
          <h4>Directory</h4>
          <a href="#categories">All Categories</a>
          <a href="#towns">Browse Towns</a>
          <a href="#contact">Add Listing</a>
          <a href="#">Deals & Coupons</a>
        </div>

        <div class="footer-links">
          <h4>Communities</h4>
          {towns.map(t => <a href={`#${t.name.toLowerCase().replace(/\s/g, '-')}`}>{t.name}</a>)}
        </div>

        <div class="footer-links">
          <h4>Company</h4>
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Service</a>
        </div>
      </div>

      <div class="footer-bottom">
        <p>&copy; 2026 JacksonCountyMS.com &mdash; Part of the County Directory Network</p>
      </div>
    </div>
  </footer>

</Layout>

<style>
  /* ════════════════════ HEADER ════════════════════ */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(13, 33, 55, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    transition: background 0.3s;
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 72px;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .logo-mark {
    width: 44px;
    height: 44px;
    background: var(--navy-light);
    border-radius: var(--radius-sm);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    line-height: 1;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .logo-jc {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--white);
    letter-spacing: -0.5px;
  }

  .logo-ms {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.55rem;
    color: var(--gold);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .logo-text { display: flex; flex-direction: column; }

  .logo-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--white);
    line-height: 1.2;
  }

  .logo-sub {
    font-size: 0.7rem;
    color: var(--gold);
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .nav-desktop {
    display: flex;
    gap: 2rem;
    margin-left: auto;
  }

  .nav-desktop a {
    color: rgba(255,255,255,0.8);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.3px;
    transition: color 0.2s;
    position: relative;
  }

  .nav-desktop a:hover { color: var(--white); }

  .nav-desktop a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gold);
    transition: width 0.25s;
  }

  .nav-desktop a:hover::after { width: 100%; }

  .header-cta { margin-left: 1rem; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: 8px;
    margin-left: auto;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: 0.3s;
  }

  .nav-mobile {
    display: none;
    flex-direction: column;
    padding: 1rem var(--gutter) 1.5rem;
    background: var(--navy);
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .nav-mobile a {
    color: rgba(255,255,255,0.85);
    padding: 0.75rem 0;
    font-weight: 600;
    font-size: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .nav-mobile a:hover { color: var(--gold); }

  /* ════════════════════ BUTTONS ════════════════════ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.6rem;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    transition: all 0.25s;
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  .btn-sm { padding: 0.5rem 1.2rem; font-size: 0.85rem; }
  .btn-lg { padding: 0.9rem 2.2rem; font-size: 1rem; }

  .btn-gold {
    background: var(--gold);
    color: var(--navy);
    border-color: var(--gold);
  }

  .btn-gold:hover {
    background: var(--gold-light);
    border-color: var(--gold-light);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(232,160,32,0.35);
  }

  .btn-white {
    background: var(--white);
    color: var(--navy);
    border-color: var(--white);
  }

  .btn-white:hover {
    background: var(--cream);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-ghost {
    background: transparent;
    color: var(--white);
    border-color: rgba(255,255,255,0.35);
  }

  .btn-ghost:hover {
    border-color: var(--white);
    background: rgba(255,255,255,0.08);
    transform: translateY(-1px);
  }

  /* ════════════════════ HERO ════════════════════ */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(13,33,55,0.85) 0%, rgba(13,33,55,0.5) 40%, rgba(13,33,55,0.7) 100%),
      linear-gradient(135deg, rgba(26,127,122,0.15) 0%, transparent 60%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 8rem 0 6rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    display: inline-block;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.25rem;
    padding: 0.4rem 1rem;
    background: rgba(232,160,32,0.12);
    border-radius: 100px;
    border: 1px solid rgba(232,160,32,0.2);
  }

  .hero h1 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.8);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
    font-weight: 300;
  }

  .hero-search { max-width: 600px; margin: 0 auto 2.5rem; }

  .search-box {
    display: flex;
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    position: relative;
  }

  .search-icon {
    position: absolute;
    left: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--gray-400);
    pointer-events: none;
  }

  .search-box input {
    flex: 1;
    border: none;
    padding: 1rem 1rem 1rem 3rem;
    font-size: 1rem;
    font-family: var(--font-body);
    color: var(--gray-800);
    outline: none;
    background: transparent;
    min-width: 0;
  }

  .search-box input::placeholder { color: var(--gray-400); }

  .search-box .btn {
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    padding: 1rem 1.8rem;
    font-size: 0.95rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .stat {
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
  }

  .stat strong {
    color: var(--gold);
    font-size: 1.4rem;
    font-family: var(--font-heading);
    margin-right: 0.35rem;
  }

  .stat-divider {
    width: 1px;
    height: 24px;
    background: rgba(255,255,255,0.2);
  }

  .hero-wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    z-index: 3;
    line-height: 0;
  }

  .hero-wave svg {
    width: 100%;
    height: 80px;
  }

  /* ════════════════════ SECTION HEADERS ════════════════════ */
  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3.5rem;
  }

  .section-eyebrow {
    display: inline-block;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    color: var(--navy);
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .section-header p {
    color: var(--gray-600);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* ════════════════════ TOWNS ════════════════════ */
  .towns {
    padding: 5rem 0;
    background: var(--white);
  }

  .towns-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .town-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 2rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .town-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--teal), var(--teal-light));
    transform: scaleX(0);
    transition: transform 0.3s;
    transform-origin: left;
  }

  .town-card:hover {
    border-color: var(--teal);
    box-shadow: var(--shadow-glow);
    transform: translateY(-4px);
  }

  .town-card:hover::before { transform: scaleX(1); }

  .town-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .town-card h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 0.4rem;
  }

  .town-card p {
    color: var(--gray-600);
    font-size: 0.9rem;
    line-height: 1.5;
    flex: 1;
  }

  .town-arrow {
    color: var(--teal);
    font-size: 1.2rem;
    margin-top: 1rem;
    transition: transform 0.25s;
  }

  .town-card:hover .town-arrow { transform: translateX(6px); }

  /* ════════════════════ SHOWCASE ════════════════════ */
  .showcase {
    padding: 0 0 5rem;
  }

  .showcase-card {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 2.4 / 1;
    box-shadow: var(--shadow-lg);
  }

  .showcase-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 6s ease;
  }

  .showcase-card:hover img { transform: scale(1.05); }

  .showcase-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(13,33,55,0.85) 0%, transparent 60%);
    display: flex;
    flex-direction: column;
