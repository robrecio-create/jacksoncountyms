---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import businessData from '../../data/businesses.json';
import { createClient } from '@supabase/supabase-js';

export function getStaticPaths() {
  const businesses = businessData as any[];
  return businesses.map(biz => ({
    params: { slug: biz.slug },
    props: { business: biz },
  }));
}

const { business } = Astro.props;
const biz = business as any;

// Fetch photos from Supabase at build time
let photos: any[] = [];
const supabaseUrl = import.meta.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;

if (supabaseUrl && supabaseKey) {
  try {
    const supabase = createClient(supabaseUrl, supabaseKey);
    // Look up business by county + slug to get UUID
    const { data: sbBiz } = await supabase
      .from('businesses')
      .select('id')
      .eq('county', 'jackson')
      .eq('slug', biz.slug)
      .single();

    if (sbBiz) {
      const { data: photoData } = await supabase
        .from('business_photos')
        .select('*')
        .eq('business_id', sbBiz.id)
        .order('is_primary', { ascending: false })
        .order('sort_order', { ascending: true });

      if (photoData) photos = photoData;
    }
  } catch (e) {
    // Silently fail — photos are optional
  }
}

const primaryPhoto = photos.find((p: any) => p.is_primary) || photos[0];
const otherPhotos = photos.filter((p: any) => p !== primaryPhoto);

// Find related businesses (same category, same city, excluding self)
const allBusinesses = businessData as any[];
const related = allBusinesses
  .filter(b =>
    b.slug !== biz.slug &&
    (b.categories?.[0] === biz.categories?.[0] || b.location?.[0] === biz.location?.[0])
  )
  .slice(0, 3);
---

<Layout title={`${biz.title} — Jackson County MS`}>
  <Header activePage="Listings" />

  <section class="page-hero">
    <div class="container">
      <a href="/listings/" class="back-link">&larr; All Listings</a>
      <div class="biz-header">
        <div>
          <h1>{biz.title}</h1>
          <div class="biz-badges">
            {biz.featured && <span class="badge badge-featured">Featured</span>}
            {biz.tags?.includes('locally-owned') && <span class="badge badge-local">Locally Owned</span>}
          </div>
        </div>
      </div>
      <div class="biz-quick-info">
        {biz.categories?.[0] && (
          <a href={`/categories/${biz.categories[0].toLowerCase().replace(/[&\s]+/g, '-').replace(/--+/g, '-')}/`} class="quick-tag">
            {biz.categories[0]}
          </a>
        )}
        {biz.location?.[0] && (
          <a href={`/locations/${biz.location[0].toLowerCase().replace(/\s+/g, '-')}/`} class="quick-tag">
            📍 {biz.location[0]}
          </a>
        )}
      </div>
    </div>
  </section>

  {photos.length > 0 && (
    <section class="biz-gallery-section">
      <div class="container">
        <div class="biz-gallery">
          {primaryPhoto && (
            <div class="gallery-hero">
              <img
                src={primaryPhoto.url}
                alt={primaryPhoto.alt_text || biz.title}
                loading="eager"
                class="gallery-hero-img"
                data-lightbox
              />
            </div>
          )}
          {otherPhotos.length > 0 && (
            <div class="gallery-thumbs">
              {otherPhotos.map((photo: any) => (
                <img
                  src={photo.url}
                  alt={photo.alt_text || biz.title}
                  loading="lazy"
                  class="gallery-thumb"
                  data-lightbox
                />
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="biz-content">
    <div class="container">
      <div class="biz-layout">
        <div class="biz-main">
          {biz.content && (
            <div class="biz-description">
              <h2>About</h2>
              <p>{biz.content}</p>
            </div>
          )}

          {biz.deal_title && (
            <div class="deal-section">
              <div class="deal-header">
                <span class="deal-icon">🎟️</span>
                <h2>Current Deal</h2>
              </div>
              <div class="deal-box">
                <h3>{biz.deal_title}</h3>
                {biz.deal_description && <p>{biz.deal_description}</p>}
                {biz.deal_expiry && <span class="deal-expiry">Expires: {biz.deal_expiry}</span>}
              </div>
            </div>
          )}

          {related.length > 0 && (
            <div class="related-section">
              <h2>Related Businesses</h2>
              <div class="related-grid">
                {related.map((r: any) => (
                  <a href={`/listing/${r.slug}/`} class="related-card">
                    <h4>{r.title}</h4>
                    <div class="related-meta">
                      {r.categories?.[0] && <span>{r.categories[0]}</span>}
                      {r.location?.[0] && <span>📍 {r.location[0]}</span>}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <aside class="biz-sidebar">
          <div class="sidebar-card">
            <h3>Contact & Location</h3>

            {biz.address && (
              <div class="sidebar-item">
                <span class="sidebar-icon">📍</span>
                <div>
                  <strong>Address</strong>
                  <p>{biz.address}</p>
                </div>
              </div>
            )}

            {biz.phone && (
              <div class="sidebar-item">
                <span class="sidebar-icon">📞</span>
                <div>
                  <strong>Phone</strong>
                  <p><a href={`tel:${biz.phone.replace(/[^\d+]/g, '')}`}>{biz.phone}</a></p>
                </div>
              </div>
            )}

            {biz.email && (
              <div class="sidebar-item">
                <span class="sidebar-icon">✉️</span>
                <div>
                  <strong>Email</strong>
                  <p><a href={`mailto:${biz.email}`}>{biz.email}</a></p>
                </div>
              </div>
            )}

            {biz.website && (
              <div class="sidebar-item">
                <span class="sidebar-icon">🌐</span>
                <div>
                  <strong>Website</strong>
                  <p><a href={biz.website} target="_blank" rel="noopener noreferrer">{biz.website.replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '')}</a></p>
                </div>
              </div>
            )}

            {biz.address && (
              <a
                href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(biz.address)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-teal"
              >
                Get Directions &rarr;
              </a>
            )}

            <div class="claim-divider"></div>
            <div class="claim-block">
              <span class="claim-icon">🏢</span>
              <strong>Own this business?</strong>
              <p>Claim this listing to update your info, add photos, post deals, and connect with customers.</p>
              <a href={`/claim/${biz.slug}/`} class="btn btn-gold">Claim This Listing</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
    padding: 8rem 0 3rem;
  }

  .back-link {
    display: inline-block;
    color: rgba(255,255,255,0.6);
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--white); }

  .biz-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .biz-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
  }

  .badge-featured {
    color: var(--gold);
    background: rgba(232,160,32,0.15);
    border: 1px solid rgba(232,160,32,0.3);
  }

  .badge-local {
    color: var(--teal-light);
    background: rgba(26,127,122,0.15);
    border: 1px solid rgba(26,127,122,0.3);
  }

  .biz-quick-info {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .quick-tag {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.8);
    background: rgba(255,255,255,0.1);
    padding: 0.3rem 0.8rem;
    border-radius: 100px;
    transition: background 0.2s;
  }

  .quick-tag:hover { background: rgba(255,255,255,0.18); }

  .biz-content {
    padding: 3rem 0 5rem;
    background: var(--gray-100);
  }

  .biz-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .biz-main {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .biz-description {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .biz-description h2 {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--navy);
    margin-bottom: 0.75rem;
  }

  .biz-description p {
    color: var(--gray-600);
    line-height: 1.8;
  }

  .deal-section {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }

  .deal-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .deal-icon { font-size: 1.4rem; }

  .deal-header h2 {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--navy);
  }

  .deal-box {
    background: rgba(232,160,32,0.06);
    border: 1px solid rgba(232,160,32,0.2);
    border-radius: var(--radius-md);
    padding: 1.5rem;
  }

  .deal-box h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--navy);
    margin-bottom: 0.4rem;
  }

  .deal-box p {
    color: var(--gray-600);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }

  .deal-expiry {
    font-size: 0.8rem;
    color: var(--gray-400);
  }

  .related-section h2 {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--navy);
    margin-bottom: 1rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .related-card {
    padding: 1.25rem;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    transition: all 0.25s;
  }

  .related-card:hover {
    border-color: var(--teal);
    transform: translateY(-2px);
  }

  .related-card h4 {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--navy);
    margin-bottom: 0.4rem;
  }

  .related-meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    font-size: 0.78rem;
    color: var(--gray-600);
  }

  .sidebar-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 2rem;
    position: sticky;
    top: 90px;
  }

  .sidebar-card h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--navy);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--gray-200);
  }

  .sidebar-item {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .sidebar-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .sidebar-item strong {
    display: block;
    font-size: 0.8rem;
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.1rem;
  }

  .sidebar-item p {
    font-size: 0.9rem;
    color: var(--navy);
    margin: 0;
    line-height: 1.4;
    word-break: break-word;
  }

  .sidebar-item a {
    color: var(--teal);
    transition: color 0.2s;
  }

  .sidebar-item a:hover { color: var(--teal-light); text-decoration: underline; }

  .claim-divider {
    border-top: 1px solid var(--gray-200);
    margin: 1.25rem 0;
  }

  .claim-block {
    text-align: center;
  }

  .claim-icon {
    font-size: 1.75rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .claim-block strong {
    display: block;
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--navy);
    margin-bottom: 0.35rem;
  }

  .claim-block p {
    color: var(--gray-600);
    font-size: 0.82rem;
    line-height: 1.5;
    margin: 0 0 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.8rem 1.6rem;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    transition: all 0.25s;
    margin-top: 0.5rem;
  }

  .btn-teal {
    background: var(--teal);
    color: var(--white);
    border-color: var(--teal);
  }

  .btn-teal:hover {
    background: var(--teal-light);
    transform: translateY(-1px);
    box-shadow: var(--shadow-glow);
  }

  .btn-gold {
    background: var(--gold);
    color: var(--navy);
    border-color: var(--gold);
    margin-top: 0;
  }

  .btn-gold:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(232,160,32,0.35);
  }

  /* Photo Gallery */
  .biz-gallery-section {
    padding: 2rem 0 0;
    background: var(--gray-100);
  }

  .biz-gallery {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .gallery-hero {
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-height: 480px;
  }

  .gallery-hero-img {
    width: 100%;
    height: 100%;
    max-height: 480px;
    object-fit: cover;
    cursor: pointer;
    transition: transform 0.3s;
  }

  .gallery-hero-img:hover {
    transform: scale(1.01);
  }

  .gallery-thumbs {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
  }

  .gallery-thumb {
    width: 100px;
    height: 75px;
    object-fit: cover;
    border-radius: var(--radius-md);
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .gallery-thumb:hover {
    border-color: var(--teal);
    transform: scale(1.05);
  }

  /* Lightbox */
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    cursor: pointer;
  }

  .lightbox-overlay img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    cursor: default;
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.5rem;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    background: none;
    border: none;
    line-height: 1;
    padding: 0.5rem;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .lightbox-close:hover { opacity: 1; }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    color: white;
    font-size: 2.5rem;
    cursor: pointer;
    background: rgba(0,0,0,0.3);
    border: none;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .lightbox-nav:hover { opacity: 1; }
  .lightbox-prev { left: 1rem; }
  .lightbox-next { right: 1rem; }

  @media (max-width: 900px) {
    .biz-layout {
      grid-template-columns: 1fr;
    }
    .sidebar-card { position: static; }
    .related-grid { grid-template-columns: 1fr; }
    .gallery-hero { max-height: 320px; }
    .gallery-hero-img { max-height: 320px; }
  }
</style>

<script>
  // Simple lightbox
  document.addEventListener('DOMContentLoaded', () => {
    const images = document.querySelectorAll('[data-lightbox]');
    if (!images.length) return;

    const srcs = Array.from(images).map(img => (img as HTMLImageElement).src);
    let currentIdx = 0;

    function openLightbox(idx: number) {
      currentIdx = idx;
      const overlay = document.createElement('div');
      overlay.className = 'lightbox-overlay';
      overlay.innerHTML = `
        <button class="lightbox-close">&times;</button>
        ${srcs.length > 1 ? '<button class="lightbox-nav lightbox-prev">&lsaquo;</button>' : ''}
        <img src="${srcs[idx]}" alt="Photo" />
        ${srcs.length > 1 ? '<button class="lightbox-nav lightbox-next">&rsaquo;</button>' : ''}
      `;

      overlay.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.classList.contains('lightbox-overlay') || target.classList.contains('lightbox-close')) {
          overlay.remove();
        } else if (target.classList.contains('lightbox-prev')) {
          currentIdx = (currentIdx - 1 + srcs.length) % srcs.length;
          (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx];
        } else if (target.classList.contains('lightbox-next')) {
          currentIdx = (currentIdx + 1) % srcs.length;
          (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx];
        }
      });

      document.addEventListener('keydown', function handler(e) {
        if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', handler); }
        if (e.key === 'ArrowLeft') { currentIdx = (currentIdx - 1 + srcs.length) % srcs.length; (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx]; }
        if (e.key === 'ArrowRight') { currentIdx = (currentIdx + 1) % srcs.length; (overlay.querySelector('img') as HTMLImageElement).src = srcs[currentIdx]; }
      });

      document.body.appendChild(overlay);
    }

    images.forEach((img, idx) => {
      img.addEventListener('click', () => openLightbox(idx));
    });
  });
</script>
